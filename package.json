{
  "name": "goodkind.io",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "scripts": {
    "build:js": "NODE_ENV=production node build.mjs",
    "build:js:dev": "NODE_ENV=development node build.mjs",
    "watch:js": "NODE_ENV=development node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "alpinejs": "^3.15.12",
    "htmx.org": "^2.0.10",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/cli": "^4.2.2",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
